{
  "title": "CloudNotes Production Dashboard", 
  "refresh": "5s", 
  "version": 1, 
  "time": {
    "to": "now", 
    "from": "now-1h"
  }, 
  "timezone": "browser", 
  "schemaVersion": 36, 
  "panels": [
    {
      "gridPos": {
        "y": 0, 
        "h": 4, 
        "w": 4, 
        "x": 0
      }, 
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          }, 
          "thresholds": {
            "steps": [
              {
                "color": "red", 
                "value": null
              }, 
              {
                "color": "green", 
                "value": 1
              }
            ], 
            "mode": "absolute"
          }
        }
      }, 
      "type": "stat", 
      "targets": [
        {
          "expr": "up{job=\"backend\"}", 
          "refId": "A"
        }
      ], 
      "title": "Backend Status"
    }, 
    {
      "gridPos": {
        "y": 0, 
        "h": 4, 
        "w": 4, 
        "x": 4
      }, 
      "type": "stat", 
      "targets": [
        {
          "expr": "sum(notes_created_total)", 
          "refId": "A"
        }
      ], 
      "title": "Total Notes Created"
    }, 
    {
      "gridPos": {
        "y": 0, 
        "h": 4, 
        "w": 4, 
        "x": 8
      }, 
      "type": "stat", 
      "targets": [
        {
          "expr": "sum(notes_deleted_total)", 
          "refId": "A"
        }
      ], 
      "title": "Total Notes Deleted"
    }, 
    {
      "gridPos": {
        "y": 0, 
        "h": 4, 
        "w": 4, 
        "x": 12
      }, 
      "type": "stat", 
      "targets": [
        {
          "expr": "sum(notes_updated_total)", 
          "refId": "A"
        }
      ], 
      "title": "Total Notes Updated"
    }, 
    {
      "gridPos": {
        "y": 4, 
        "h": 8, 
        "w": 12, 
        "x": 0
      }, 
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2, 
            "drawStyle": "line", 
            "fillOpacity": 10
          }
        }
      }, 
      "type": "timeseries", 
      "targets": [
        {
          "expr": "rate(flask_http_request_total[5m])", 
          "refId": "A", 
          "legendFormat": "{{method}} {{status}}"
        }
      ], 
      "title": "HTTP Request Rate (5m)"
    }, 
    {
      "gridPos": {
        "y": 4, 
        "h": 8, 
        "w": 12, 
        "x": 12
      }, 
      "fieldConfig": {
        "defaults": {
          "unit": "bytes", 
          "custom": {
            "lineWidth": 2, 
            "drawStyle": "line", 
            "fillOpacity": 10
          }
        }
      }, 
      "type": "timeseries", 
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"backend\"}", 
          "refId": "A", 
          "legendFormat": "Memory (bytes)"
        }
      ], 
      "title": "Backend Memory Usage"
    }
  ]
}