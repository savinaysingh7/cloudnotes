# Terraform S3 Remote State Backend (EXAMPLE)
#
# To use this:
# 1. Create an S3 bucket: aws s3 mb s3://cloudnotes-tfstate-<your-account-id>
# 2. Create a DynamoDB table: aws dynamodb create-table --table-name terraform-locks \
#      --attribute-definitions AttributeName=LockID,AttributeType=S \
#      --key-schema AttributeName=LockID,KeyType=HASH \
#      --billing-mode PAY_PER_REQUEST
# 3. Rename this file to backend.tf
# 4. Run: terraform init -migrate-state
#
# WARNING: Do NOT apply this while the infra is live without proper state migration.

terraform {
  backend "s3" {
    bucket         = "cloudnotes-tfstate"
    key            = "prod/terraform.tfstate"
    region         = "us-east-1"
    dynamodb_table = "terraform-locks"
    encrypt        = true
  }
}
